LOAD DATABASE
     FROM sqlite:///tmp/pgloader_sqlite_test.db
     INTO postgresql://test:test@localhost:5433/targetdb

     WITH include drop, create tables, create indexes, reset sequences,
          foreign keys, truncate, comments, triggers,
          batch size = 10000, batch concurrency = 2, prefetch rows = 5000,
          batch rows per range = 50000, on error stop

     SET maintenance_work_mem to '128MB',
         work_mem to '64MB',
         client_encoding to 'UTF8',
         standard_conforming_strings to 'on',
         search_path to 'public'

     -- Integer types: SQLite INTEGER can be 1-8 bytes → bigint; auto_increment → bigserial
     CAST type integer to bigint drop typemod,
          type integer auto_increment to bigserial drop typemod using int-to-id,
          type tinyint to smallint drop typemod,
          type smallint to smallint drop typemod,
          type mediumint to integer drop typemod,
          type bigint to bigint drop typemod,
          type int to integer drop typemod,
          -- Float types: preserve precision
          type real to real drop typemod,
          type float to float drop typemod,
          type double to double precision drop typemod,
          -- Decimal types: preserve typemod
          type numeric to numeric($mod),
          type decimal to decimal($mod),
          -- String types: text for all variants
          type text to text drop typemod,
          type varchar to text drop typemod,
          type nvarchar to text drop typemod,
          type char to text drop typemod,
          type nchar to text drop typemod,
          type clob to text drop typemod,
          -- Binary types: blob → bytea
          type blob to bytea drop typemod,
          -- Boolean types: numeric boolean → native boolean
          type boolean to boolean drop typemod,
          type bool to boolean drop typemod,
          -- Date/time types
          type datetime to timestamptz drop typemod using zero-dates-to-null,
          type timestamp to timestamp drop typemod,
          type date to date drop typemod,
          type time to time drop typemod

     INCLUDING ONLY TABLE NAMES MATCHING ~/^main\./, 'data_%'

     EXCLUDING TABLE NAMES MATCHING ~/sqlite_/, ~/_bak$/, 'temp_%'

     BEFORE LOAD DO
     $$ create schema if not exists public; $$

     AFTER LOAD DO
     $$ analyze; $$,
     $$ create index if not exists idx_users_email on public.users (email); $$,
     $$ create index if not exists idx_orders_date on public.orders (order_date); $$;
